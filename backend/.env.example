# Copie este arquivo para .env e preencha com suas credenciais do Supabase
# .env NÃO deve ser commitado (já está no .gitignore)

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Connection string Postgres (em Project Settings → Database → Connection string)
# Substitua [YOUR-PASSWORD] pela senha que você definiu ao criar o projeto
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.SEU_PROJETO.supabase.co:5432/postgres
